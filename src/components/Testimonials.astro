---
const response = await fetch(
  "https://docs.google.com/spreadsheets/d/e/2PACX-1vRwaZquwkCYSqP_jT0K0YZ6qMtTqn9vXuytvzolFW2v_TkTh85NM-hLPdW9yW-3hZA99YQiyNwmDQ2O/pub?gid=2119829741&single=true&output=csv&t=" + Date.now()
);

const csvText = await response.text();

// split rows
const rows = csvText.split("\n").slice(1);

// convert to objects
const testimonials = rows
  .map((row) => row.split(","))
  .filter((row) => row.length >= 6 && row[1]) // remove empty rows
  .map((cols) => ({
    name: cols[1]?.trim() || "",
    email: cols[2]?.trim() || "",
    linkedin: cols[3]?.trim() || "#",
    college: cols[4]?.trim() || "",
    review: cols[5]?.trim() || ""
  }));
---

<section id="testimonials" class="p-8 sm:p-12 md:p-16 lg:p-24">
  <div>
    <div class="mb-10">
      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-6xl font-bold text-gray-900">
        Testimonials
      </h2>

      <div class="w-[75px] h-[5px] mt-2 rounded-full bg-blue-500"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 hover:shadow-md transition">

          <p class="text-gray-600 mb-4 italic">
            "{t.review}"
          </p>

          <h3 class="font-semibold text-lg text-gray-900 mb-2">
            {t.name}
          </h3>

          <p class="text-sm text-gray-500 mb-1">
            🎓 {t.college}
          </p>

          <p class="text-sm text-gray-500 mb-2">
            📧 {t.email}
          </p>

          <a
            href={t.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-blue-500 hover:underline"
          >
            🔗 LinkedIn Profile
          </a>

        </div>
      ))}
    </div>
  </div>
</section>