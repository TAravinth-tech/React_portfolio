---

const sheetURL =
"https://docs.google.com/spreadsheets/d/e/2PACX-1vRwaZquwkCYSqP_jT0K0YZ6qMtTqn9vXuytvzolFW2v_TkTh85NM-hLPdW9yW-3hZA99YQiyNwmDQ2O/pub?gid=2119829741&single=true&output=csv";

// prevent caching
const response = await fetch(`${sheetURL}&t=${Date.now()}`, {
headers: {
"Cache-Control": "no-cache"
}
});

const csvText = await response.text();

// split rows safely
const rows = csvText
.split("\n")
.slice(1)
.filter((row) => row.trim() !== "");

// convert rows to objects
const testimonials = rows
.map((row) => row.split(","))
.filter((cols) => cols.length >= 6 && cols[1]?.trim())
.map((cols) => ({
name: cols[1]?.trim() || "",
email: cols[2]?.trim() || "",
college: cols[4]?.trim() || "",
review: cols[5]?.trim() || ""
}));
----

<section id="testimonials" class="p-8 sm:p-12 md:p-16 lg:p-24">
  <div>

```
<div class="mb-10">
  <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-6xl font-bold text-gray-900">
    Testimonials
  </h2>

  <div class="w-[75px] h-[5px] mt-2 rounded-full bg-blue-500"></div>
</div>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

  {testimonials.length === 0 && (
    <p class="text-gray-500">No testimonials yet.</p>
  )}

  {testimonials.map((t) => (
    <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 hover:shadow-md transition">

      {/* Review */}
      <p class="text-gray-600 mb-4 italic">
        "{t.review}"
      </p>

      {/* Name */}
      <h3 class="font-semibold text-lg text-gray-900 mb-2">
        {t.name}
      </h3>

      {/* College */}
      {t.college && (
        <p class="text-sm text-gray-500 mb-1">
          🎓 {t.college}
        </p>
      )}

      {/* Email */}
      {t.email && (
        <p class="text-sm text-gray-500">
          📧 {t.email}
        </p>
      )}

    </div>
  ))}

</div>
